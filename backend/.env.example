# ============================================================
# Backend Environment Variables — Example File
# ============================================================
#
# HOW TO USE:
#   cp .env.example .env
#   Then fill in your real values in .env
#
# WHY .env.example EXISTS:
#   - .env is gitignored (never committed — contains secrets)
#   - .env.example is committed — it documents what variables are needed
#   - Every developer copies it and fills in their own values
#
# SECURITY RULE: Never put real secrets in .env.example
# ============================================================

# ── Server ──────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://expense_user:expense_pass@localhost:5432/expense_tracker

# Direct (non-pooled) connection — used by Prisma for migrations
# On Neon: use the non-pooled connection string here
# On local PostgreSQL: same as DATABASE_URL
DIRECT_URL=postgresql://expense_user:expense_pass@localhost:5432/expense_tracker

# Used by Docker Compose to create the database
POSTGRES_USER=expense_user
POSTGRES_PASSWORD=expense_pass
POSTGRES_DB=expense_tracker

# ── JWT Authentication ───────────────────────────────────────
# IMPORTANT: Use long, random strings in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_here_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── AI Provider ──────────────────────────────────────────────
# Options: "gemini" | "rule-based"
# Set to "rule-based" if you don't have a Gemini API key
AI_PROVIDER=rule-based
GEMINI_API_KEY=your_gemini_api_key_here

# ── Storage Provider ─────────────────────────────────────────
# Options: "local" | "cloudinary" | "s3"
STORAGE_PROVIDER=local
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# Cloudinary (only needed if STORAGE_PROVIDER=cloudinary)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# AWS S3 (only needed if STORAGE_PROVIDER=s3)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
AWS_S3_BUCKET=

# ── Testing ─────────────────────────────────────────────────
# Separate database for integration tests (keeps test data isolated from dev data)
# If not set, tests fall back to DATABASE_URL
TEST_DATABASE_URL=postgresql://expense_user:expense_pass@localhost:5432/expense_tracker_test

# ── CORS ────────────────────────────────────────────────────
# In production, set to your deployed frontend URL
# Example: https://expenseai.vercel.app
FRONTEND_URL=http://localhost:5173

# ── Rate Limiting ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
